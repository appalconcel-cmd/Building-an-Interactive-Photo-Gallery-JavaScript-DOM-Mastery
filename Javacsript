/* Interactive Photo Gallery 
   Functionality: upDate and unDo 
*/

function upDate(previewPic) {
  // 1. Log to the console to verify the event is triggering
  // This helps you see if 'previewPic' is being passed correctly
  console.log("Mouse over event triggered!");
  console.log("Source: " + previewPic.src);
  console.log("Alt text: " + previewPic.alt);

  // 2. Select the element with the id of 'image'
  let displayBox = document.getElementById('image');

  // 3. Change the text of the display box to the alt text of the preview image
  displayBox.innerHTML = previewPic.alt;

  // 4. Change the background image of the display box to the source of the preview image
  // Note: We use the CSS url() format here
  displayBox.style.backgroundImage = "url('" + previewPic.src + "')";
}

function unDo() {
  // 1. Select the element with the id of 'image'
  let displayBox = document.getElementById('image');

  // 2. Reset the background image back to the original value (empty)
  displayBox.style.backgroundImage = "url('')";

  // 3. Reset the text back to the original instruction
  displayBox.innerHTML = "Hover over an image below to display here.";
  
  console.log("Mouse out event: Display reset.");
}
