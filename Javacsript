/**
 * Interactive Photo Gallery Logic
 * Functions to handle dynamic DOM updates on mouse events.
 */

function upDate(previewPic) {
    /* 1. Debugging: Confirm the function is receiving the correct element */
    console.log("Mouse over event triggered on:", previewPic.alt);
    console.log("Image Source:", previewPic.src);

    /* 2. Target the main display area (id="image") */
    const displayBox = document.getElementById('image');

    /* 3. Update the background image using the source of the hovered thumbnail */
    // Logic: Combine the string 'url()' with the dynamic path
    displayBox.style.backgroundImage = "url('" + previewPic.src + "')";

    /* 4. Update the text to match the 'alt' description of the thumbnail */
    displayBox.innerHTML = previewPic.alt;
}

function unDo() {
    /* 1. Target the main display area */
    const displayBox = document.getElementById('image');

    /* 2. Revert the background image back to the original state (empty) */
    displayBox.style.backgroundImage = "url('')";

    /* 3. Revert the text back to the default instructional message */
    displayBox.innerHTML = "Hover over an image below to display here.";

    console.log("Mouse out event: Display reset to default.");
}
